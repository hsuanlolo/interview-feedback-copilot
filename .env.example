# Interview Feedback Copilot — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic Claude API key. Leave blank to run in baseline (rule-based) mode.
ANTHROPIC_API_KEY=

# Model to use for extraction and synthesis. Claude Opus 4.8 recommended for quality.
LLM_MODEL=claude-opus-4-8

# Set to "true" to skip all real LLM calls and use mock responses (useful for tests).
LLM_MOCK_MODE=false

# Set to "true" to force deterministic baseline extractor even when API key is set.
BASELINE_MODE=false

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local development. Change to postgresql+asyncpg://... for production.
DATABASE_URL=sqlite+aiosqlite:///./interview_copilot.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
